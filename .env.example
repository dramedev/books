# Copy this file to .env and fill in your key to enable the AI chat assistant.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Email (Gmail SMTP) - sends signup verification codes
# For local dev without sending real email, use:
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# EMAIL_HOST_USER is your Gmail address; EMAIL_HOST_PASSWORD must be a
# Gmail App Password (requires 2-Step Verification enabled on the account).
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
